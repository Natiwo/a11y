{
	"name": "@natiwo/a11y-morpheus",
	"version": "0.1.0",
	"description": "Morpheus Design System preset for @natiwo/a11y",
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"sideEffects": false,
	"keywords": [
		"a11y",
		"accessibility",
		"morpheus",
		"neumorphism",
		"design-system",
		"preset"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/natiwo/a11y",
		"directory": "packages/morpheus"
	},
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"@natiwo/a11y": ">=0.1.0"
	},
	"devDependencies": {
		"@natiwo/a11y": "workspace:*"
	},
	"scripts": {
		"build": "tsdown",
		"test": "vitest run",
		"lint": "biome check src/",
		"format": "biome format --write src/",
		"typecheck": "tsc --noEmit",
		"size": "size-limit"
	},
	"size-limit": [
		{
			"path": "dist/index.js",
			"limit": "1 kB"
		}
	]
}
